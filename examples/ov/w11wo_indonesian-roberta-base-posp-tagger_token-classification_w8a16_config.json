{
  "export": {
    "opset_version": 17,
    "batch_size": 1,
    "export_params": true,
    "do_constant_folding": true,
    "verbose": false,
    "dynamo": false,
    "enable_hierarchy_tags": true,
    "clean_onnx": false,
    "hierarchy_tag_format": "full",
    "input_tensors": [
      {
        "name": "input_ids",
        "dtype": "int32",
        "shape": [
          1,
          512
        ],
        "value_range": [
          0,
          50265
        ]
      },
      {
        "name": "attention_mask",
        "dtype": "int32",
        "shape": [
          1,
          512
        ],
        "value_range": [
          0,
          2
        ]
      }
    ],
    "output_tensors": [
      {
        "name": "logits"
      }
    ]
  },
  "optim": {
    "clamp_constant_values": true
  },
  "quant": {
    "mode": "qdq",
    "samples": 10,
    "calibration_method": "minmax",
    "weight_type": "uint8",
    "activation_type": "uint16",
    "per_channel": false,
    "symmetric": false,
    "save_calibration": false,
    "distribution": "uniform",
    "seed": null,
    "calibration_load_path": null,
    "calibration_save_path": null,
    "op_types_to_quantize": null,
    "nodes_to_exclude": null,
    "task": "token-classification",
    "model_name": "w11wo/indonesian-roberta-base-posp-tagger"
  },
  "compile": {
    "execution_provider": "openvino",
    "provider_options": {},
    "enable_ep_context": true,
    "embed_context": false,
    "compiler": "ort",
    "qnn_sdk_root": null,
    "validate": true
  },
  "loader": {
    "task": "token-classification",
    "model_class": "AutoModelForTokenClassification",
    "model_type": "roberta"
  },
  "eval_dataset": {
    "build_script": "scripts/e2e_eval/datasets/build_indonlu_posp.py",
    "path": "~/.cache/winml/eval_datasets/build_indonlu_posp",
    "metric": "overall_f1",
    "columns_mapping": {
      "label_column": "pos_tags"
    }
  }
}
