{
  "export": {
    "opset_version": 17,
    "batch_size": 1,
    "export_params": true,
    "do_constant_folding": true,
    "verbose": false,
    "dynamo": false,
    "enable_hierarchy_tags": true,
    "clean_onnx": false,
    "hierarchy_tag_format": "full",
    "input_tensors": [
      {
        "name": "pixel_values",
        "dtype": "float32",
        "shape": [
          1,
          3,
          640,
          640
        ],
        "value_range": [
          0,
          1
        ]
      }
    ],
    "output_tensors": [
      {
        "name": "logits"
      }
    ]
  },
  "optim": {},
  "quant": null,
  "compile": {
    "execution_provider": "openvino",
    "provider_options": {},
    "enable_ep_context": true,
    "embed_context": false,
    "compiler": "ort",
    "qnn_sdk_root": null,
    "validate": true
  },
  "loader": {
    "task": "image-segmentation",
    "model_class": "AutoModelForSemanticSegmentation",
    "model_type": "segformer"
  },
  "eval_option": {
    "dataset": {
      "path": "danjacobellis/scene_parse_150",
      "split": "validation",
      "columns_mapping": {
        "annotation_column": "annotation"
      }
    },
    "label_mapping_file": "scripts/e2e_eval/datasets/ade20k_gt_to_model_label.json"
  }
}
