{
  "export": {
    "opset_version": 17,
    "batch_size": 1,
    "export_params": true,
    "do_constant_folding": true,
    "verbose": false,
    "dynamo": false,
    "enable_hierarchy_tags": true,
    "clean_onnx": false,
    "hierarchy_tag_format": "full",
    "input_tensors": [
      {
        "name": "input_ids",
        "dtype": "int32",
        "shape": [
          1,
          512
        ],
        "value_range": [
          0,
          250002
        ]
      },
      {
        "name": "attention_mask",
        "dtype": "int32",
        "shape": [
          1,
          512
        ],
        "value_range": [
          0,
          2
        ]
      }
    ],
    "output_tensors": [
      {
        "name": "logits"
      }
    ]
  },
  "optim": {
    "clamp_constant_values": true
  },
  "quant": null,
  "compile": {
    "execution_provider": "openvino",
    "provider_options": {},
    "enable_ep_context": true,
    "embed_context": false,
    "compiler": "ort",
    "qnn_sdk_root": null,
    "validate": true
  },
  "loader": {
    "task": "zero-shot-classification",
    "model_class": "AutoModelForSequenceClassification",
    "model_type": "xlm-roberta"
  },
  "eval_option": {
    "dataset": {
      "path": "nyu-mll/multi_nli",
      "split": "validation_matched",
      "columns_mapping": {
        "input_column": "premise",
        "label_column": "genre",
        "candidate_labels": "fiction,government,slate,telephone,travel"
      }
    }
  }
}
