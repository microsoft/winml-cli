{
  "export": {
    "opset_version": 17,
    "batch_size": 1,
    "export_params": true,
    "do_constant_folding": true,
    "verbose": false,
    "dynamo": false,
    "enable_hierarchy_tags": true,
    "clean_onnx": false,
    "hierarchy_tag_format": "full",
    "input_tensors": [
      {
        "name": "input_ids",
        "dtype": "int32",
        "shape": [
          1,
          512
        ],
        "value_range": [
          0,
          50265
        ]
      },
      {
        "name": "attention_mask",
        "dtype": "int32",
        "shape": [
          1,
          512
        ],
        "value_range": [
          0,
          2
        ]
      }
    ],
    "output_tensors": [
      {
        "name": "logits"
      }
    ]
  },
  "optim": {
    "clamp_constant_values": true
  },
  "quant": null,
  "compile": {
    "execution_provider": "vitisai",
    "provider_options": {},
    "enable_ep_context": false,
    "embed_context": false,
    "compiler": "ort",
    "qnn_sdk_root": null,
    "validate": true
  },
  "loader": {
    "task": "text-classification",
    "model_class": "AutoModelForSequenceClassification",
    "model_type": "roberta"
  },
  "eval": {
    "task": "text-classification",
    "device": "npu",
    "dataset": {
      "path": "tweet_eval",
      "name": "sentiment",
      "columns_mapping": {
        "input_column": "text"
      }
    }
  }
}
