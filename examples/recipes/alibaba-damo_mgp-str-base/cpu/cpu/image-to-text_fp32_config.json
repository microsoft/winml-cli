{
  "export": {
    "opset_version": 17,
    "batch_size": 1,
    "export_params": true,
    "do_constant_folding": true,
    "verbose": false,
    "dynamo": false,
    "enable_hierarchy_tags": true,
    "clean_onnx": false,
    "hierarchy_tag_format": "full",
    "input_tensors": [
      {
        "name": "pixel_values",
        "dtype": "float32",
        "shape": [1, 3, 32, 128],
        "value_range": [0, 1]
      }
    ],
    "output_tensors": [
      {"name": "char_logits"},
      {"name": "bpe_logits"},
      {"name": "wp_logits"}
    ]
  },
  "optim": {},
  "quant": null,
  "compile": null,
  "loader": {
    "task": "image-to-text",
    "model_class": "MgpstrForSceneTextRecognition",
    "model_type": "mgp-str"
  }
}
