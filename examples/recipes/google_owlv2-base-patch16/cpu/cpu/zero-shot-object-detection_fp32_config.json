{
  "export": {
    "opset_version": 17,
    "batch_size": 1,
    "export_params": true,
    "do_constant_folding": true,
    "verbose": false,
    "dynamo": false,
    "enable_hierarchy_tags": true,
    "clean_onnx": false,
    "hierarchy_tag_format": "full",
    "input_tensors": [
      {
        "name": "input_ids",
        "dtype": "int32",
        "shape": [
          1,
          16
        ],
        "value_range": [
          0,
          49408
        ]
      },
      {
        "name": "pixel_values",
        "dtype": "float32",
        "shape": [
          1,
          3,
          960,
          960
        ],
        "value_range": [
          0,
          1
        ]
      },
      {
        "name": "attention_mask",
        "dtype": "int32",
        "shape": [
          1,
          16
        ],
        "value_range": [
          0,
          2
        ]
      }
    ],
    "output_tensors": [
      {
        "name": "logits"
      },
      {
        "name": "pred_boxes"
      },
      {
        "name": "text_embeds"
      },
      {
        "name": "image_embeds"
      }
    ]
  },
  "optim": {
    "clamp_constant_values": true
  },
  "quant": null,
  "loader": {
    "task": "zero-shot-object-detection",
    "model_class": "AutoModelForZeroShotObjectDetection",
    "model_type": "owlv2"
  }
}