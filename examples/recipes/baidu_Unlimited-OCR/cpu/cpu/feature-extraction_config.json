{
  "export": {
    "opset_version": 17,
    "batch_size": 1,
    "export_params": true,
    "do_constant_folding": true,
    "verbose": false,
    "dynamo": false,
    "enable_hierarchy_tags": true,
    "clean_onnx": false,
    "hierarchy_tag_format": "full",
    "input_tensors": [
      {
        "name": "pixel_values",
        "dtype": "float32",
        "shape": [
          1,
          3,
          1024,
          1024
        ],
        "value_range": [
          0,
          1
        ]
      }
    ],
    "output_tensors": [
      {
        "name": "image_embeds"
      }
    ]
  },
  "optim": {},
  "quant": null,
  "loader": {
    "task": "feature-extraction",
    "model_type": "unlimited-ocr",
    "trust_remote_code": true
  }
}
