{
  "export": {
    "opset_version": 17,
    "batch_size": 1,
    "export_params": true,
    "do_constant_folding": true,
    "verbose": false,
    "dynamo": false,
    "enable_hierarchy_tags": true,
    "clean_onnx": false,
    "hierarchy_tag_format": "full",
    "input_tensors": [
      {
        "name": "pixel_values",
        "dtype": "float32",
        "shape": [
          1,
          3,
          224,
          224
        ],
        "value_range": [
          0,
          1
        ]
      }
    ],
    "output_tensors": [
      {
        "name": "last_hidden_state"
      }
    ]
  },
  "optim": {},
  "quant": null,
  "compile": {
    "execution_provider": "qnn",
    "provider_options": {},
    "enable_ep_context": true,
    "embed_context": false,
    "compiler": "ort",
    "qnn_sdk_root": null,
    "validate": true
  },
  "loader": {
    "task": "image-feature-extraction",
    "model_class": "AutoModel",
    "model_type": "vit"
  },
  "eval_option": {
    "dataset": {
      "path": "timm/mini-imagenet",
      "split": "test",
      "samples": 1000
    }
  }
}
