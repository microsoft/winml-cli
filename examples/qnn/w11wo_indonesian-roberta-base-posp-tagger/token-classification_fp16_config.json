{
  "export": {
    "opset_version": 17,
    "batch_size": 1,
    "export_params": true,
    "do_constant_folding": true,
    "verbose": false,
    "dynamo": false,
    "enable_hierarchy_tags": true,
    "clean_onnx": false,
    "hierarchy_tag_format": "full",
    "input_tensors": [
      {
        "name": "input_ids",
        "dtype": "int32",
        "shape": [
          1,
          512
        ],
        "value_range": [
          0,
          50265
        ]
      },
      {
        "name": "attention_mask",
        "dtype": "int32",
        "shape": [
          1,
          512
        ],
        "value_range": [
          0,
          2
        ]
      }
    ],
    "output_tensors": [
      {
        "name": "logits"
      }
    ]
  },
  "optim": {
    "clamp_constant_values": true
  },
  "quant": null,
  "compile": {
    "execution_provider": "qnn",
    "provider_options": {},
    "enable_ep_context": true,
    "embed_context": false,
    "compiler": "ort",
    "qnn_sdk_root": null,
    "validate": true
  },
  "loader": {
    "task": "token-classification",
    "model_class": "AutoModelForTokenClassification",
    "model_type": "roberta"
  },
  "eval_option": {
    "dataset": {
      "path": "~/.cache/winml/eval_datasets/build_indonlu_posp",
      "columns_mapping": {
        "label_column": "pos_tags"
      }
    },
    "dataset_script": "scripts/e2e_eval/datasets/build_indonlu_posp.py"
  }
}
