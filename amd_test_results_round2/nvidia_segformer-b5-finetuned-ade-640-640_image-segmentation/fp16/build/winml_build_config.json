{
  "export": {
    "opset_version": 17,
    "batch_size": 1,
    "export_params": true,
    "do_constant_folding": true,
    "verbose": false,
    "dynamo": false,
    "enable_hierarchy_tags": true,
    "clean_onnx": false,
    "hierarchy_tag_format": "full",
    "input_tensors": [
      {
        "name": "pixel_values",
        "dtype": "float32",
        "shape": [
          1,
          3,
          640,
          640
        ],
        "value_range": [
          0,
          1
        ]
      }
    ],
    "output_tensors": [
      {
        "name": "logits"
      }
    ]
  },
  "optim": {
    "gelu_fusion": true,
    "matmul_add_fusion": true
  },
  "quant": null,
  "compile": {
    "execution_provider": "vitisai",
    "provider_options": {},
    "enable_ep_context": false,
    "embed_context": false,
    "compiler": "ort",
    "qnn_sdk_root": null,
    "validate": true
  },
  "loader": {
    "task": "image-segmentation",
    "model_class": "AutoModelForSemanticSegmentation",
    "model_type": "segformer"
  }
}